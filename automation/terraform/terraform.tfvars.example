subscription_id                = "794194cd-a4b7-4024-970c-9533c4babff0"
automation_resource_group_name = "rg-automation"
target_resource_group_name     = "rg-azure-monitor-lab"
automation_account_name        = "aa-law-retention"

# Must be >5 minutes in the future (RFC3339, UTC shown here).
schedule_start_time = "2026-07-22T03:00:00Z"

analytics_retention_in_days = -1
total_retention_in_days     = 730
workspace_name_filter       = ""

# Scope of workspaces the runbook configures:
#   ResourceGroup (default) | Subscription | ManagementGroup
scope_mode              = "ResourceGroup"
# Only used when scope_mode = "ManagementGroup"
scope_management_group  = ""
management_group_name   = ""
# Only used when scope_mode = "Subscription" to target a DIFFERENT subscription than the
# Automation Account's own. Empty = the identity's home subscription.
scope_subscription_id   = ""
# Where to grant the managed identity: resource_group | subscription | management_group
role_assignment_scope   = "resource_group"
