{
  "mode": "Indexed",
  "parameters": {
    "effect": {
      "type": "String",
      "metadata": {
        "displayName": "Effect",
        "description": "The policy effect. Audit reports workspaces with a non-matching retention, Deny blocks writes that would set a non-matching retention, and DeployIfNotExists remediates the retention to the specified value."
      },
      "allowedValues": [
        "Audit",
        "Deny",
        "DeployIfNotExists"
      ],
      "defaultValue": "DeployIfNotExists"
    },
    "workspaceRetentionInDays": {
      "type": "Integer",
      "metadata": {
        "displayName": "Workspace retention (days)",
        "description": "Workspace-level analytics data retention in days. This becomes the default analytics retention for all Analytics tables that still inherit the workspace setting. Allowed range is 30-730. Defaults to 30 (the minimum)."
      },
      "defaultValue": 30
    }
  },
  "policyRule": {
    "if": {
      "allOf": [
        {
          "field": "type",
          "equals": "Microsoft.OperationalInsights/workspaces"
        },
        {
          "field": "Microsoft.OperationalInsights/workspaces/retentionInDays",
          "notEquals": "[parameters('workspaceRetentionInDays')]"
        }
      ]
    },
    "then": {
      "effect": "[parameters('effect')]",
      "details": {
        "type": "Microsoft.OperationalInsights/workspaces",
        "name": "[field('name')]",
        "roleDefinitionIds": [
          "/providers/Microsoft.Authorization/roleDefinitions/92aaf0da-9dab-42b6-94a3-d43ce8d16293"
        ],
        "existenceCondition": {
          "field": "Microsoft.OperationalInsights/workspaces/retentionInDays",
          "equals": "[parameters('workspaceRetentionInDays')]"
        },
        "deployment": {
          "properties": {
            "mode": "incremental",
            "parameters": {
              "workspaceName": {
                "value": "[field('name')]"
              },
              "location": {
                "value": "[field('location')]"
              },
              "workspaceRetentionInDays": {
                "value": "[parameters('workspaceRetentionInDays')]"
              }
            },
            "template": {
              "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
              "contentVersion": "1.0.0.0",
              "parameters": {
                "workspaceName": {
                  "type": "string"
                },
                "location": {
                  "type": "string"
                },
                "workspaceRetentionInDays": {
                  "type": "int"
                }
              },
              "resources": [
                {
                  "type": "Microsoft.OperationalInsights/workspaces",
                  "apiVersion": "2025-07-01",
                  "name": "[parameters('workspaceName')]",
                  "location": "[parameters('location')]",
                  "properties": {
                    "retentionInDays": "[parameters('workspaceRetentionInDays')]"
                  }
                }
              ]
            }
          }
        }
      }
    }
  }
}
